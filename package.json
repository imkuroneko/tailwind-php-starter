{
  "name": "tailwind-php-starter",
  "version": "1.0.0",
  "description": "Uso de Tailwind CSS CLI para compilar CSS en proyecto PHP vanilla",
  "private": true,
  "scripts": {
    "dev": "tailwindcss -i ./src/input.css -o ./assets/css/tailwind.css --watch",
    "build": "tailwindcss -i ./src/input.css -o ./assets/css/tailwind.css --minify"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
